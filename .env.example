# ============================================================
# SIGEM — Variables de entorno de ejemplo
# ============================================================
# Copiar este archivo como .env y completar con valores reales.
# NUNCA subir el archivo .env al repositorio (está en .gitignore).
# ============================================================

# Entorno de ejecución: development | production | ci
SIGEM_ENV=development

# Ruta personalizada a la base de datos (opcional)
# Si está vacío, usa la ruta por defecto: database/sigem.db
SIGEM_DB_PATH=

# Nivel de logging: DEBUG | INFO | WARNING | ERROR
SIGEM_LOG_LEVEL=INFO

# Ruta del directorio de logs (opcional)
# Si está vacío, usa la ruta por defecto: logs/
SIGEM_LOG_DIR=
